<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="mviProject"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MviProject">

        <!-- HOME SCREEN — launches first -->
        <activity
            android:name=".mvi.m.ui.SummaryActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Other screens -->
        <activity android:name=".mvi.m.ui.AttendanceActivity" />
        <activity android:name=".mvi.m.ui.AddStudentActivity" />
        <activity android:name=".mvi.m.ui.ReportActivity" />

    </application>

</manifest>